# ============================================================
#  Template de configuration locale — À COPIER, PAS À MODIFIER ICI
# ============================================================
#  1. Copier ce fichier sous le nom : application-local.properties
#     (même dossier, juste sans ".example")
#  2. Remplir vos vraies valeurs ci-dessous.
#  3. Lancer l'appli avec le profil "local" :
#        -Dspring.profiles.active=local
#     (ou dans IntelliJ : Run Configuration → VM options)
#
#  /!\ application-local.properties est git-ignoré : NE JAMAIS le committer.
# ============================================================

# URL JDBC complète (optionnel — si absent, reprend la valeur par défaut)
#spring.datasource.url=jdbc:mysql://127.0.0.1:3306/worktogether?serverTimezone=Europe/Paris&useSSL=false&allowPublicKeyRetrieval=true

# Identifiants MySQL locaux
spring.datasource.username=
spring.datasource.password=
