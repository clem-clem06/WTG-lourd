<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.wtg.views.UsersController"
            stylesheets="@style.css"
            styleClass="root-pane">

    <!-- ═══════════════════════════════════════════════════════════
         TOP : navbar avec bouton retour
    ═══════════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="navbar">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>

            <Label text="WorkTogether — Utilisateurs" styleClass="nav-logo"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="← Retour"
                    onAction="#onRetour"
                    styleClass="btn-logout"/>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════
         CENTER : entête + feedback + 2 colonnes (liste | formulaire)
    ═══════════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="20">
                <padding><Insets top="32" right="40" bottom="40" left="40"/></padding>

                <!-- Entête de page -->
                <VBox spacing="6">
                    <Label text="Gestion des utilisateurs" styleClass="page-title"/>
                    <Label text="Sélectionnez une ligne pour modifier, ou remplissez le formulaire pour créer un compte."
                           styleClass="page-subtitle"/>
                </VBox>

                <!-- Message de feedback (caché par défaut) -->
                <Label fx:id="feedbackLabel"
                       visible="false"
                       managed="false"
                       wrapText="true"
                       maxWidth="Infinity"/>

                <!-- ─────────────────────────────────────────────
                     Deux colonnes : tableau à gauche, formulaire à droite
                ───────────────────────────────────────────────── -->
                <HBox spacing="20" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">

                    <!-- ───── Colonne GAUCHE : liste du personnel ───── -->
                    <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="PERSONNEL EXISTANT" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="countLabel" styleClass="count-badge"/>
                        </HBox>

                        <TableView fx:id="usersTable" prefHeight="360" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol"    text="ID"    prefWidth="60"  minWidth="50"/>
                                <TableColumn fx:id="emailCol" text="Email" prefWidth="280" minWidth="180"/>
                                <TableColumn fx:id="roleCol"  text="Rôle"  prefWidth="140" minWidth="110"/>
                            </columns>
                            <placeholder>
                                <Label text="Aucun membre du personnel enregistré."/>
                            </placeholder>
                        </TableView>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Button text="Supprimer"
                                    fx:id="deleteBtn"
                                    onAction="#onSupprimer"
                                    disable="true"
                                    styleClass="btn-delete"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="selectionHint" styleClass="selection-hint"
                                   text="Aucune ligne sélectionnée"/>
                        </HBox>
                    </VBox>

                    <!-- ───── Colonne DROITE : formulaire ───── -->
                    <VBox spacing="16" styleClass="card" prefWidth="380" minWidth="340">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <Label fx:id="formTitle" text="NOUVEAU COMPTE" styleClass="section-title"/>

                        <!-- GridPane = chaque label / champ parfaitement aligné -->
                        <GridPane hgap="12" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints minWidth="90" prefWidth="90"/>
                                <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                            </columnConstraints>

                            <!-- Ligne 0 : Email -->
                            <Label text="Email"
                                   styleClass="field-label"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="emailField"
                                       promptText="prenom.nom@wtg.fr"
                                       styleClass="text-field"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <!-- Ligne 1 : Mot de passe -->
                            <Label text="Mot de passe"
                                   styleClass="field-label"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <PasswordField fx:id="passwordField"
                                           promptText="Minimum 8 caractères"
                                           styleClass="text-field"
                                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <!-- Ligne 2 : Rôle -->
                            <Label text="Rôle"
                                   styleClass="field-label"
                                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="roleCombo"
                                      maxWidth="Infinity"
                                      styleClass="combo-box"
                                      GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        </GridPane>

                        <Region VBox.vgrow="ALWAYS"/>

                        <!-- Boutons d'action du formulaire -->
                        <HBox spacing="10">
                            <Button fx:id="cancelEditBtn"
                                    text="Annuler"
                                    onAction="#onAnnulerEdition"
                                    visible="false"
                                    managed="false"
                                    styleClass="btn-logout"/>
                            <Button fx:id="submitBtn"
                                    text="Créer le compte"
                                    onAction="#onSubmit"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"
                                    styleClass="btn-login"/>
                        </HBox>
                    </VBox>

                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
