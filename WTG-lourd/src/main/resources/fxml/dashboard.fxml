<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<!--
  BorderPane = layout avec 5 zones : top, bottom, left, right, center
  On utilise top (navbar) + center (contenu scrollable)
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.wtg.views.DashboardController"
            stylesheets="@style.css"
            styleClass="root-pane">

    <!-- ═══════════════════════════════════════════════════════════
         TOP : barre de navigation
    ═══════════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="navbar">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>

            <!-- Logo -->
            <Label text="WorkTogether" styleClass="nav-logo"/>
            <Label text="Gestion interne" styleClass="nav-subtitle"/>

            <!-- Region avec HGrow=ALWAYS = pousse le reste à droite (spacer) -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Badge du rôle (couleur ajoutée dynamiquement dans le controller) -->
            <Label fx:id="roleBadge" styleClass="badge-role"/>

            <!-- Email de l'utilisateur connecté -->
            <Label fx:id="emailLabel" styleClass="nav-email"/>

            <!-- Bouton Déconnexion -->
            <Button text="Déconnexion"
                    onAction="#onLogout"
                    styleClass="btn-logout"/>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════
         CENTER : contenu scrollable
    ═══════════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="32">
                <padding><Insets top="40" right="48" bottom="40" left="48"/></padding>

                <!-- Message d'accueil -->
                <VBox spacing="6">
                    <Label text="Tableau de bord" styleClass="page-title"/>
                    <Label text="Que souhaitez-vous gérer aujourd'hui ?" styleClass="page-subtitle"/>
                </VBox>

                <!-- ─────────────────────────────────────────────
                     SECTION ADMIN (cachée si pas ROLE_ADMIN)
                     fx:id → le controller peut la masquer
                ───────────────────────────────────────────────── -->
                <VBox fx:id="adminSection" spacing="14">
                    <Label text="ADMINISTRATION" styleClass="section-title"/>

                    <!--
                      TilePane = grille qui s'adapte automatiquement
                      au nombre de colonnes selon la largeur de la fenêtre
                    -->
                    <TilePane hgap="16" vgap="16" prefColumns="3" prefTileWidth="260" prefTileHeight="140">

                        <!-- CARTE : Utilisateurs -->
                        <VBox onMouseClicked="#onUsers" styleClass="card" spacing="8">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                            <Label text="👥" styleClass="card-icon"/>
                            <Label text="Utilisateurs" styleClass="card-title"/>
                            <Label text="Gérer les comptes du personnel." styleClass="card-desc" wrapText="true"/>
                        </VBox>

                        <!-- CARTE : Baies -->
                        <VBox onMouseClicked="#onBaies" styleClass="card" spacing="8">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                            <Label text="🗄️" styleClass="card-icon"/>
                            <Label text="Baies" styleClass="card-title"/>
                            <Label text="Gérer le stock des 30 baies et leurs unités." styleClass="card-desc" wrapText="true"/>
                        </VBox>

                        <!-- CARTE : Offres -->
                        <VBox onMouseClicked="#onOffres" styleClass="card" spacing="8">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                            <Label text="📦" styleClass="card-icon"/>
                            <Label text="Offres commerciales" styleClass="card-title"/>
                            <Label text="Base, Start-up, PME, Entreprise." styleClass="card-desc" wrapText="true"/>
                        </VBox>

                    </TilePane>
                </VBox>

                <!-- ─────────────────────────────────────────────
                     SECTION COMPTABLE (visible par Comptable ET Admin)
                ───────────────────────────────────────────────── -->
                <VBox spacing="14">
                    <Label text="COMPTABILITÉ" styleClass="section-title"/>

                    <TilePane hgap="16" vgap="16" prefColumns="3" prefTileWidth="260" prefTileHeight="140">

                        <!-- CARTE : Clients -->
                        <VBox onMouseClicked="#onClients" styleClass="card" spacing="8">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                            <Label text="🏢" styleClass="card-icon"/>
                            <Label text="Clients" styleClass="card-title"/>
                            <Label text="Consulter la liste des entreprises clientes." styleClass="card-desc" wrapText="true"/>
                        </VBox>

                        <!-- CARTE : Réservations -->
                        <VBox onMouseClicked="#onReservations" styleClass="card" spacing="8">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                            <Label text="📋" styleClass="card-icon"/>
                            <Label text="Réservations" styleClass="card-title"/>
                            <Label text="Consulter toutes les commandes et leur statut." styleClass="card-desc" wrapText="true"/>
                        </VBox>

                    </TilePane>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
